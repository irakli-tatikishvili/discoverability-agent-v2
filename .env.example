# Required for chat/LLM features
OPENAI_API_KEY=your_openai_api_key_here

# Optional: LangSmith tracing (set LANGCHAIN_TRACING_V2=true to enable)
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_PROJECT=similarweb-agent
# LANGCHAIN_API_KEY=your_langsmith_api_key

# Optional: Port for local dev (default: 3001)
# PORT=3001
